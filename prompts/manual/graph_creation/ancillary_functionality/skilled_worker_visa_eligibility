// UK Skilled worker visa eligibility
digraph {
	rankdir=TB
	node [fontname=Arial fontsize=10]
	edge [fontname=Arial fontsize=9]
	start [label="UK Skilled Worker Visa Eligibility Assessment" fillcolor=lightgreen shape=box style="rounded,filled"]
	start -> check_switching_eligibility
	check_switching_eligibility [label="If applicant is switching from Student visa in the UK, have they completed their course (or at least 24 months of a PhD)?" fillcolor=lightblue shape=diamond style=filled]
	check_switching_eligibility -> has_approved_employer [label="Yes Or Not Applicable"]
	check_switching_eligibility -> INELIGIBLE_student_not_completed [label=No]
	has_approved_employer [label="Does the applicant have a job offer from a UK employer approved by the Home Office?" fillcolor=lightblue shape=diamond style=filled]
	has_approved_employer -> has_certificate_of_sponsorship [label=Yes]
	has_approved_employer -> INELIGIBLE_no_approved_employer [label=No]
	has_certificate_of_sponsorship [label="Does the applicant have a Certificate of Sponsorship (CoS) from their employer?" fillcolor=lightblue shape=diamond style=filled]
	has_certificate_of_sponsorship -> check_genuine_vacancy [label=Yes]
	has_certificate_of_sponsorship -> INELIGIBLE_no_cos [label=No]
	check_genuine_vacancy [label="Is this a genuine vacancy that meets credibility requirements?" fillcolor=orange shape=box style=filled]
	check_genuine_vacancy -> check_genuine_employment [label="Appears Genuine"]
	check_genuine_vacancy -> INELIGIBLE_not_genuine_vacancy [label="Credibility Concerns"]
	check_genuine_employment [label="Is this genuine direct employment by the sponsor (not third-party contracting)?" fillcolor=orange shape=box style=filled]
	check_genuine_employment -> check_guaranteed_salary_structure [label=Yes]
	check_genuine_employment -> INELIGIBLE_third_party_working [label=No]
	check_guaranteed_salary_structure [label="Is the salary guaranteed basic gross pay with valid contract structure?" fillcolor=orange shape=box style=filled]
	check_guaranteed_salary_structure -> check_part_time_eligibility [label="Meets Requirement"]
	check_guaranteed_salary_structure -> INELIGIBLE_salary_structure_invalid [label="Below Or Invalid"]
	check_part_time_eligibility [label="If part-time: does actual gross annual salary meet the general threshold (even if hourly rate pro-rates correctly)?" fillcolor=orange shape=box style=filled]
	check_part_time_eligibility -> check_transitional_eligibility [label="Meets Requirement"]
	check_part_time_eligibility -> INELIGIBLE_part_time_below_threshold [label="Below Threshold"]
	check_transitional_eligibility [label="Did the applicant receive their first Certificate of Sponsorship for Skilled Worker visa before 4 April 2024?" fillcolor=lightblue shape=diamond style=filled]
	check_transitional_eligibility -> check_transitional_salary [label=Yes]
	check_transitional_eligibility -> check_occupation_eligibility [label=No]
	check_transitional_salary [label="Does the salary meet transitional requirements?" fillcolor=orange shape=box style=filled]
	check_transitional_salary -> check_english_language [label="Meets Requirement"]
	check_transitional_salary -> INELIGIBLE_salary_too_low [label="Below Threshold"]
	check_occupation_eligibility [label="Is the job eligible for Skilled Worker visa?" fillcolor=lightcyan shape=box style=filled]
	check_occupation_eligibility -> determine_salary_threshold [label="Higher Skilled"]
	check_occupation_eligibility -> check_salary_list_or_shortage [label="Medium Skilled"]
	check_occupation_eligibility -> INELIGIBLE_occupation_not_eligible [label="Not Eligible"]
	check_salary_list_or_shortage [label="Is the job on the Immigration Salary List OR Temporary Shortage List?" fillcolor=lightblue shape=diamond style=filled]
	check_salary_list_or_shortage -> determine_salary_threshold [label=Yes]
	check_salary_list_or_shortage -> INELIGIBLE_medium_skilled_not_on_list [label=No]
	determine_salary_threshold [label="Determine which salary rules apply based on job type" fillcolor=lightgray shape=circle style=filled]
	determine_salary_threshold -> check_healthcare_education_salary [label="Healthcare Education"]
	determine_salary_threshold -> check_standard_salary_requirement [label=Standard]
	check_healthcare_education_salary [label="Does the salary meet healthcare/education requirements?" fillcolor=orange shape=box style=filled]
	check_healthcare_education_salary -> check_care_worker_registration [label="Meets Requirement"]
	check_healthcare_education_salary -> INELIGIBLE_salary_too_low [label="Below Threshold"]
	check_care_worker_registration [label="If applicant is a care worker (6135) or senior care worker (6136) in England, is employer registered with Care Quality Commission?" fillcolor=lightblue shape=diamond style=filled]
	check_care_worker_registration -> check_english_language [label="Yes Or Not Applicable"]
	check_care_worker_registration -> INELIGIBLE_cqc_not_registered [label=No]
	check_standard_salary_requirement [label="Does the salary meet the standard requirements?" fillcolor=orange shape=box style=filled]
	check_standard_salary_requirement -> check_english_language [label="Meets Requirement"]
	check_standard_salary_requirement -> check_reduced_salary_eligibility [label="Below Threshold"]
	check_reduced_salary_eligibility [label="Is the applicant eligible for reduced salary requirements?" fillcolor=plum shape=hexagon style=filled]
	check_reduced_salary_eligibility -> check_english_language [label="Eligible Via Any Path"]
	check_reduced_salary_eligibility -> INELIGIBLE_salary_too_low [label="Not Eligible"]
	check_english_language [label="Does the applicant meet English language requirements?" fillcolor=plum shape=hexagon style=filled]
	check_english_language -> check_financial_requirement [label="Meets Requirement"]
	check_english_language -> INELIGIBLE_english_language [label="Does Not Meet"]
	check_financial_requirement [label="Does the applicant meet financial requirements?" fillcolor=gold shape=box style=filled]
	check_financial_requirement -> ELIGIBLE [label="Meets Requirement Or Exempt"]
	check_financial_requirement -> INELIGIBLE_insufficient_funds [label="Does Not Meet"]
	ELIGIBLE [label="ELIGIBLE\n" fillcolor=green fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_no_approved_employer [label="INELIGIBLE\nNo job offer from Home Office approved employer" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_no_cos [label="INELIGIBLE\nNo Certificate of Sponsorship from employer" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_occupation_not_eligible [label="INELIGIBLE\nJob occupation code not eligible for Skilled Worker visa" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_medium_skilled_not_on_list [label="INELIGIBLE\nMedium skilled job not on Immigration Salary List or Temporary Shortage List" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_salary_too_low [label="INELIGIBLE\nSalary does not meet minimum requirements for this visa" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_cqc_not_registered [label="INELIGIBLE\nEmployer not registered with Care Quality Commission (required for care workers in England)" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_english_language [label="INELIGIBLE\nDoes not meet English language requirements" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_insufficient_funds [label="INELIGIBLE\nInsufficient funds to support self in UK" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_student_not_completed [label="INELIGIBLE\nStudent visa holder has not completed course (or 24 months of PhD)" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_third_party_working [label="INELIGIBLE\nNot genuine direct employment - sponsor is contracting worker to third party" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_salary_structure_invalid [label="INELIGIBLE\nSalary structure does not meet requirements (e.g., includes ineligible allowances, bonuses, equity; zero-hours contract; hours exceed 48/week cap for calculation)" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_part_time_below_threshold [label="INELIGIBLE\nPart-time salary: hourly rate may be adequate (pro-rated going rate) but actual gross annual salary is below the general threshold" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_not_genuine_vacancy [label="INELIGIBLE\nHome Office has concerns that this is not a genuine vacancy or role lacks credibility" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
}
