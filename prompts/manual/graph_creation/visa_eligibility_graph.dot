// UK Skilled Worker Visa Eligibility
digraph {
	rankdir=TB
	node [fontname=Arial fontsize=10]
	edge [fontname=Arial fontsize=9]
	start [label="UK Skilled Worker Visa Eligibility Assessment" fillcolor=lightgreen shape=box style="rounded,filled"]
	start -> has_approved_employer
	has_approved_employer [label="Does the applicant have a job offer from a UK e..." fillcolor=lightblue shape=diamond style=filled]
	has_approved_employer -> has_certificate_of_sponsorship [label=Yes]
	has_approved_employer -> INELIGIBLE_no_approved_employer [label=No]
	has_certificate_of_sponsorship [label="Does the applicant have a Certificate of Sponso..." fillcolor=lightblue shape=diamond style=filled]
	has_certificate_of_sponsorship -> check_occupation_eligibility [label=Yes]
	has_certificate_of_sponsorship -> INELIGIBLE_no_cos [label=No]
	check_occupation_eligibility [label="Is the job eligible for Skilled Worker visa?" fillcolor=lightcyan shape=box style=filled]
	check_occupation_eligibility -> determine_salary_threshold [label="Higher Skilled"]
	check_occupation_eligibility -> check_salary_list_or_shortage [label="Medium Skilled"]
	check_occupation_eligibility -> INELIGIBLE_occupation_not_eligible [label="Not Eligible"]
	check_salary_list_or_shortage [label="Is the job on the Immigration Salary List OR Te..." fillcolor=lightblue shape=diamond style=filled]
	check_salary_list_or_shortage -> determine_salary_threshold [label=Yes]
	check_salary_list_or_shortage -> INELIGIBLE_medium_skilled_not_on_list [label=No]
	determine_salary_threshold [label="Determine which salary rules apply based on job..." fillcolor=lightgray shape=circle style=filled]
	determine_salary_threshold -> check_healthcare_education_salary [label="Healthcare Education"]
	determine_salary_threshold -> check_standard_salary_requirement [label=Standard]
	check_healthcare_education_salary [label="Does the salary meet healthcare/education requi..." fillcolor=orange shape=box style=filled]
	check_healthcare_education_salary -> check_care_worker_registration [label="Meets Requirement"]
	check_healthcare_education_salary -> INELIGIBLE_salary_too_low [label="Below Threshold"]
	check_care_worker_registration [label="If applicant is a care worker (6135) or senior ..." fillcolor=lightblue shape=diamond style=filled]
	check_care_worker_registration -> check_english_language [label="Yes Or Not Applic..."]
	check_care_worker_registration -> INELIGIBLE_cqc_not_registered [label=No]
	check_standard_salary_requirement [label="Does the salary meet the standard requirements?" fillcolor=orange shape=box style=filled]
	check_standard_salary_requirement -> check_english_language [label="Meets Requirement"]
	check_standard_salary_requirement -> check_reduced_salary_eligibility [label="Below Threshold"]
	check_reduced_salary_eligibility [label="Is the applicant eligible for reduced salary re..." fillcolor=plum shape=hexagon style=filled]
	check_reduced_salary_eligibility -> check_english_language [label="Eligible Via Any ..."]
	check_reduced_salary_eligibility -> INELIGIBLE_salary_too_low [label="Not Eligible"]
	check_english_language [label="Does the applicant meet English language requir..." fillcolor=plum shape=hexagon style=filled]
	check_english_language -> check_financial_requirement [label="Meets Requirement"]
	check_english_language -> INELIGIBLE_english_language [label="Does Not Meet"]
	check_financial_requirement [label="Does the applicant meet financial requirements?" fillcolor=gold shape=box style=filled]
	check_financial_requirement -> ELIGIBLE [label="Meets Requirement..."]
	check_financial_requirement -> INELIGIBLE_insufficient_funds [label="Does Not Meet"]
	ELIGIBLE [label="ELIGIBLE\n" fillcolor=green fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_no_approved_employer [label="INELIGIBLE\nNo job offer from Home Office approved employer" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_no_cos [label="INELIGIBLE\nNo Certificate of Sponsorship from employer" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_occupation_not_eligible [label="INELIGIBLE\nJob occupation code not eligible for Skilled Worker visa" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_medium_skilled_not_on_list [label="INELIGIBLE\nMedium skilled job not on Immigration Salary List or Temporary Shortage List" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_salary_too_low [label="INELIGIBLE\nSalary does not meet minimum requirements for this visa" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_cqc_not_registered [label="INELIGIBLE\nEmployer not registered with Care Quality Commission (required for care workers in England)" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_english_language [label="INELIGIBLE\nDoes not meet English language requirements" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_insufficient_funds [label="INELIGIBLE\nInsufficient funds to support self in UK" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
}
