// UK Child benefit eligibility
digraph {
	rankdir=TB
	node [fontname=Arial fontsize=10]
	edge [fontname=Arial fontsize=9]
	start [label="UK Child Benefit Eligibility Assessment" fillcolor=lightgreen shape=box style="rounded,filled"]
	start -> has_qualifying_child
	has_qualifying_child [label="Determine child's age category for eligibility" fillcolor=lightgray shape=circle style=filled]
	has_qualifying_child -> check_child_not_working_full_time [label="Under 16"]
	has_qualifying_child -> check_education_or_extension [label="16 To 19"]
	has_qualifying_child -> INELIGIBLE_no_qualifying_child [label="20 Or Over"]
	check_education_or_extension [label="For 16-19 year olds, check if in education/training or eligible for extension" fillcolor=lightgray shape=circle style=filled]
	check_education_or_extension -> check_education_level [label="In Education Or Training"]
	check_education_or_extension -> check_extension_eligibility [label="Left Education Recently"]
	check_education_or_extension -> INELIGIBLE_no_qualifying_child [label=Neither]
	check_education_level [label="Is the child in approved (non-advanced) education or training?" fillcolor=orange shape=box style=filled]
	check_education_level -> check_child_not_working_full_time [label="Approved Education"]
	check_education_level -> INELIGIBLE_advanced_education [label="Advanced Education"]
	check_education_level -> INELIGIBLE_part_time_education [label="Part Time Insufficient"]
	check_education_level -> INELIGIBLE_employer_funded_training [label="Employer Funded"]
	check_extension_eligibility [label="Has the child (aged 16-17) left education within the last 20 weeks AND registered with a qualifying service?" fillcolor=lightblue shape=diamond style=filled]
	check_extension_eligibility -> check_child_not_working_full_time [label="Yes And Within 20 Weeks"]
	check_extension_eligibility -> INELIGIBLE_extension_not_applicable [label="No Or Expired"]
	check_child_not_working_full_time [label="Is the child working less than 24 hours per week (or not in paid work)?" fillcolor=lightblue shape=diamond style=filled]
	check_child_not_working_full_time -> check_child_not_receiving_benefits [label=Yes]
	check_child_not_working_full_time -> INELIGIBLE_child_working_full_time [label=No]
	check_child_not_receiving_benefits [label="Is the child NOT receiving certain benefits in their own right (e.g., ESA, Universal Credit)?" fillcolor=lightblue shape=diamond style=filled]
	check_child_not_receiving_benefits -> check_child_not_apprentice [label=Yes]
	check_child_not_receiving_benefits -> INELIGIBLE_child_receiving_benefits [label=No]
	check_child_not_apprentice [label="Is the child NOT in a disqualifying apprenticeship?" fillcolor=orange shape=box style=filled]
	check_child_not_apprentice -> check_claimant_residency [label="Not In Apprenticeship"]
	check_child_not_apprentice -> check_claimant_residency [label="Approved Apprenticeship"]
	check_child_not_apprentice -> INELIGIBLE_child_apprentice [label="Disqualifying Apprenticeship"]
	check_claimant_residency [label="Does the claimant meet UK residency requirements?" fillcolor=plum shape=hexagon style=filled]
	check_claimant_residency -> check_responsibility_for_child [label="Eligible Via Any Path"]
	check_claimant_residency -> INELIGIBLE_residency_requirements [label="Not Eligible"]
	check_responsibility_for_child [label="Are you responsible for the child?" fillcolor=plum shape=hexagon style=filled]
	check_responsibility_for_child -> check_no_other_claimant [label="Eligible Via Any Path"]
	check_responsibility_for_child -> INELIGIBLE_not_responsible [label="Not Eligible"]
	check_no_other_claimant [label="Check if another person is claiming Child Benefit for this child" fillcolor=lightgray shape=circle style=filled]
	check_no_other_claimant -> check_child_location [label="No Other Claimant"]
	check_no_other_claimant -> check_child_location [label="Other Claimant Agreed Transfer"]
	check_no_other_claimant -> DEFERRED_TO_HMRC [label="Disputed Multiple Claimants"]
	check_child_location [label="Determine if special rules apply based on child's location" fillcolor=lightgray shape=circle style=filled]
	check_child_location -> check_hospital_duration [label="In Hospital"]
	check_child_location -> check_care_duration [label="In Care"]
	check_child_location -> check_fostering_arrangement [label=Fostered]
	check_child_location -> check_council_not_paying [label="Normal Living"]
	check_hospital_duration [label="Has the child's cumulative time in hospital or residential accommodation exceeded 12 weeks?" fillcolor=orange shape=box style=filled]
	check_hospital_duration -> check_regularly_spending_on_child_hospital [label="Under 12 Weeks Cumulative"]
	check_hospital_duration -> check_regularly_spending_on_child_hospital [label="Over 12 Weeks Cumulative"]
	check_regularly_spending_on_child_hospital [label="Are you regularly spending money on the child while they are in hospital/residential accommodation?" fillcolor=lightblue shape=diamond style=filled]
	check_regularly_spending_on_child_hospital -> check_council_not_paying [label=Yes]
	check_regularly_spending_on_child_hospital -> INELIGIBLE_hospital_over_12_weeks [label=No]
	check_care_duration [label="Has the child been in care for 8 weeks or less, OR do they spend at least 24 hours a week at home?" fillcolor=lightblue shape=diamond style=filled]
	check_care_duration -> check_council_not_paying [label=Yes]
	check_care_duration -> INELIGIBLE_care_over_8_weeks [label=No]
	check_fostering_arrangement [label="Is the local council NOT paying towards the child's accommodation or maintenance?" fillcolor=lightblue shape=diamond style=filled]
	check_fostering_arrangement -> check_council_not_paying [label=Yes]
	check_fostering_arrangement -> INELIGIBLE_council_paying_fostering [label=No]
	check_council_not_paying [label="Is the local council NOT paying towards the child's accommodation or maintenance?" fillcolor=lightblue shape=diamond style=filled]
	check_council_not_paying -> ELIGIBLE [label=Yes]
	check_council_not_paying -> INELIGIBLE_council_paying [label=No]
	ELIGIBLE [label="ELIGIBLE\nMeets all Child Benefit eligibility requirements" fillcolor=green fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_no_qualifying_child [label="INELIGIBLE\nNo qualifying child under 16, or under 20 in approved education/training" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_child_working_full_time [label="INELIGIBLE\nChild aged 16+ is working 24 or more hours per week and not in approved education or training" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_child_receiving_benefits [label="INELIGIBLE\nChild is receiving certain benefits in their own right" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_child_apprentice [label="INELIGIBLE\nChild has started an apprenticeship in England" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_residency_requirements [label="INELIGIBLE\nDoes not meet UK residency requirements" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_not_responsible [label="INELIGIBLE\nNot responsible for the child" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_other_claimant_exists [label="INELIGIBLE\nSomeone else is already claiming Child Benefit for this child" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_hospital_over_12_weeks [label="INELIGIBLE\nChild has been in hospital or residential accommodation for more than 12 weeks and you are not regularly spending money on them" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_care_over_8_weeks [label="INELIGIBLE\nChild has been in local authority care for more than 8 weeks and does not spend at least 24 hours a week at home" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_council_paying_fostering [label="INELIGIBLE\nLocal council is paying towards the child's accommodation or maintenance (fostering)" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_council_paying [label="INELIGIBLE\nLocal council is paying towards the child's accommodation or maintenance" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_advanced_education [label="INELIGIBLE\nChild aged 16-19 is in advanced education (university degree, HNC, HND, NVQ Level 4+)" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_part_time_education [label="INELIGIBLE\nChild aged 16-19 is in part-time education (less than 12 hours per week supervised study)" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_employer_funded_training [label="INELIGIBLE\nChild aged 16-19 is in employer-funded training or training with employer agreement for future job" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	INELIGIBLE_extension_not_applicable [label="INELIGIBLE\n20-week extension not applicable (child not registered with qualifying service, extension period expired, or child turned 18)" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
	DEFERRED_TO_HMRC [label="DEFERRED\nMultiple people claim responsibility for the child and cannot agree who should claim Child Benefit" fillcolor=red fontcolor=white shape=box style="rounded,filled"]
}
